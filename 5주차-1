function y = mixedTransform(x)
    y = zeros(size(x));
    
    for i = 1:length(x)
        if x(i) < 0
            y(i) = -x(i);
        elseif x(i) == 0
            y(i) = x(i);  
        else
            y(i) = 2*x(i) + 1;     
        end
    end
end
