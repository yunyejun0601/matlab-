name=input('이름을 입력하세요','s');      %(1)
score=input('성적을 입력하세요');         %(2)
avg=mean(score);                        %(3)
fprintf("%s",name)                          
disp(score)
fprintf("%0.2f",avg)
if avg>=90                              %(4)
    fprintf("Excellent");
elseif avg>=80
    fprintf("Good");
elseif avg>=70
    fprintf("Fair");
else
    fprintf("Needs Improvement");
end
